# --- App ---
APP_ENV=development
APP_NAME=Knewron AI Localization Platform
API_V1_PREFIX=/api/v1
LOG_LEVEL=DEBUG
LOG_RETENTION_DAYS=30
SECRET_KEY=change-me-in-every-environment

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://localization:password@db:5432/localization
DATABASE_URL_SYNC=postgresql+psycopg2://localization:password@db:5432/localization

# --- Redis (Celery broker/result backend, cache, pub/sub, idempotency) ---
# Not run via docker-compose — point at a managed instance (AWS ElastiCache /
# GCP Memorystore) in staging/production, per LOCKED_Design_v1.0.md §7.3's
# scaling path. For local dev without one, run your own container, e.g.:
#   docker run -d --name dev-redis -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- ChromaDB (client-server) ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_IMAGE_MATCH_THRESHOLD=0.90
# Logical partition key stamped on every vector + applied as a query filter,
# on top of the existing per-product scoping. The only "tenant" concept in
# this codebase — set it to separate environments/deployments sharing one
# ChromaDB instance; leave as "default" for a single-deployment setup.
CHROMADB_TENANT_ID=default

# --- AI image classifier / embeddings ---
AI_IMAGE_CONFIDENCE_THRESHOLD=0.70
# Embedding backend for ChromaDB similarity matching: clip | phash | aws | gcp
#   clip  - local CLIP model via sentence-transformers (poetry install -E ml)
#   phash - dependency-light fallback, no model download (tests/CI/minimal installs)
#   aws   - Amazon Bedrock Titan Multimodal Embeddings (uses AWS_* below)
#   gcp   - Vertex AI multimodal embeddings (poetry install -E gcp; uses GCS_*/EMBEDDING_GCP_* below)
AI_EMBEDDING_BACKEND=clip
EMBEDDING_AWS_REGION=us-east-1
EMBEDDING_AWS_MODEL_ID=amazon.titan-embed-image-v1
EMBEDDING_GCP_PROJECT_ID=
EMBEDDING_GCP_LOCATION=us-central1
EMBEDDING_GCP_MODEL=multimodalembedding@001

# --- Object storage ---
# Backend: local | s3 | gcs
STORAGE_BACKEND=local
STORAGE_BUCKET=knewron-localization
STORAGE_PRESIGN_EXPIRY_SECONDS=3600
STORAGE_LOCAL_ROOT=./data/storage

# S3 (STORAGE_BACKEND=s3)
STORAGE_ENDPOINT_URL=
STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCS (STORAGE_BACKEND=gcs; poetry install -E gcp)
GCS_PROJECT_ID=
# Path to a service-account JSON key; omit to use Application Default
# Credentials (GOOGLE_APPLICATION_CREDENTIALS, workload identity, etc.)
GCS_CREDENTIALS_PATH=

# --- Auth / SSO ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
SSO_ISSUER=
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_JWKS_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=

# --- Lokalise ---
LOKALISE_API_TOKEN=
LOKALISE_PROJECT_ID=
LOKALISE_BASE_URL=https://api.lokalise.com/api2
LOKALISE_WEBHOOK_SECRET=
LOKALISE_POLL_INTERVAL_MINUTES=15

# --- Figma ---
FIGMA_ACCESS_TOKEN=
FIGMA_BASE_URL=https://api.figma.com/v1
FIGMA_MAX_CONCURRENT_REQUESTS=8
FIGMA_MAX_RETRIES=5

# --- Circuit breaker defaults ---
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# --- Audit ---
AUDIT_LOG_RETENTION_DAYS=365

# --- Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@knewron.local
